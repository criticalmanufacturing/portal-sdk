{
    "name": "portal-sdk devcontainer",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    "features": {
        "ghcr.io/devcontainers/features/dotnet": {
            "version": "10.0"
        },
        "ghcr.io/devcontainers/features/node": {
            "version": "12"
        },
        "ghcr.io/devcontainers/features/github-cli": {},
        "ghcr.io/nils-geistmann/devcontainers-features/zsh": {
            "plugins": "git dotnet node npm dotenv"
        }
    },
    "containerEnv": {
        "ZSH_DOTENV_PROMPT": "false"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csdevkit",
                "ms-dotnettools.csharp"
            ]
        },
        "settings": {
            "dotnet.solution.autoOpen": "Cmf.CustomerPortal.Sdk.sln",
            "dotnet.projectsystem.cacheInProjectFolder": false,
            "csharp.experimental.debug.hotReload": true
        }
    },
    "postCreateCommand": "echo \"alias 'cmf-portal=src/Console/bin/Debug/net10.0/cmf-portal'\" >> /home/vscode/.bashrc"
}